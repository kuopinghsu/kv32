#!/usr/bin/env bash
# cleanup — source code whitespace cleanup
#
# Usage:
#   cleanup                  Clean files that are modified/untracked in git
#                            (requires a git repo; use -all otherwise)
#   cleanup -all             Clean all files from current dir (with filter rules)
#   cleanup <file1> ...      Clean the specified files only
#
# Filter rules (applied in -all mode and when checking explicit files):
#   - Skip files named Makefile or Makefile.*
#   - Skip binary files (detected via grep -qI)
#   - Skip files that are ignored by git (git check-ignore)
#   - Skip git submodule directories (read from .gitmodules)
#   - Skip .git directory
#
# Cleanup actions per file:
#   1. Remove trailing whitespace
#   2. Convert tabs to 4 spaces
#   3. Collapse consecutive blank lines into a single blank line

set -euo pipefail

# ── Portable in-place sed ─────────────────────────────────────────────────────
# GNU sed (Linux): sed -i -e ...
# BSD sed (macOS): sed -i '' -e ...
if sed --version 2>/dev/null | grep -q GNU; then
    SED_I=(-i)
else
    SED_I=(-i '')
fi

# ── SIGINT handling ───────────────────────────────────────────────────────────
# Ctrl-C BETWEEN files   → exit immediately (_sigint_outer)
# Ctrl-C INSIDE trim_file → set flag, finish the write, exit after (_sigint_defer)
_interrupted=0
_sigint_outer() { echo ""; echo "cleanup: interrupted."; exit 130; }
_sigint_defer() { _interrupted=1; }
trap '_sigint_outer' INT

# ── trim a single file ────────────────────────────────────────────────────────
trim_file() {
    local f="$1"
    [[ -f "$f" ]] || return

    # 1. Remove trailing whitespace
    LC_ALL=C sed "${SED_I[@]}" -e 's/[[:space:]]*$//' "$f"

    # 2. Convert tabs to 4 spaces
    local tmp
    tmp="$(mktemp /tmp/cleanup.XXXXXX)"
    expand -t 4 "$f" > "$tmp" && cat "$tmp" > "$f"
    rm -f "$tmp"

    # 3. Collapse consecutive blank lines (cat -s)
    cp "$f" "$tmp"
    cat -s "$tmp" > "$f"
    rm -f "$tmp"
}

# ── collect submodule paths from .gitmodules ─────────────────────────────────
# Walk up from cwd to find the repo root
find_gitmodules() {
    local dir
    dir="$(pwd)"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/.gitmodules" ]] && { echo "$dir/.gitmodules"; return; }
        dir="$(dirname "$dir")"
    done
}

submodule_paths=()
gitmodules_file="$(find_gitmodules)"
if [[ -n "$gitmodules_file" ]]; then
    repo_root="$(dirname "$gitmodules_file")"
    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"   # ltrim
        if [[ "$line" == path* ]]; then
            sp="${line#*= }"
            submodule_paths+=("$repo_root/$sp")
        fi
    done < "$gitmodules_file"
fi

# ── detect binary files ──────────────────────────────────────────────────────
# Uses `grep -qI`: exits 0 for text files, 1 for binary files.
is_binary() {
    ! grep -qI '' "$1" 2>/dev/null
}

# ── check if a file should be excluded by the filter rules ───────────────────
is_excluded() {
    local f
    f="$(realpath "$1" 2>/dev/null || echo "$1")"
    local base
    base="$(basename "$f")"

    # Makefile names
    [[ "$base" == "Makefile"   ]] && return 0
    [[ "$base" == Makefile.*   ]] && return 0

    # .git directory (itself or any file inside it)
    [[ "$f" == *"/.git" || "$f" == *"/.git/"* ]] && return 0

    # files ignored by git
    git check-ignore -q "$1" 2>/dev/null && return 0

    # submodule directories
    for sp in "${submodule_paths[@]}"; do
        local sp_real
        sp_real="$(realpath "$sp" 2>/dev/null || echo "$sp")"
        if [[ "$f" == "$sp_real" || "$f" == "$sp_real/"* ]]; then
            return 0
        fi
    done

    return 1
}

# ── build excluded-dir list for reporting in -all mode ───────────────────────
# Just collects skip_dirs[] for informational printing; no find prune needed.
build_skip_dirs() {
    skip_dirs=()
    skip_dirs+=("./.git")
    for sp in "${submodule_paths[@]}"; do
        local rel
        rel="$(realpath --relative-to=. "$sp" 2>/dev/null || echo "${sp#./}")"
        skip_dirs+=("./$rel")
    done
}

# ── parse arguments ───────────────────────────────────────────────────────────
mode="git"
explicit_files=()

for arg in "$@"; do
    case "$arg" in
        -all) mode="all" ;;
        *)    explicit_files+=("$arg") ;;
    esac
done

[[ ${#explicit_files[@]} -gt 0 ]] && mode="files"

# ── execute ───────────────────────────────────────────────────────────────────
process_file() {
    local f="$1"
    if is_excluded "$f"; then
        echo "skip:  $f"
    elif is_binary "$f"; then
        echo "skip:  $f (binary)"
    elif [[ -f "$f" ]]; then
        echo "clean: $f"
        trap '_sigint_defer' INT   # defer Ctrl-C: finish the write first
        trim_file "$f"
        trap '_sigint_outer' INT   # restore immediate Ctrl-C between files
        if [[ $_interrupted -eq 1 ]]; then
            echo ""
            echo "cleanup: interrupted after completing $f."
            exit 130
        fi
    fi
}

case "$mode" in

    files)
        for f in "${explicit_files[@]}"; do
            process_file "$f"
        done
        ;;

    all)
        build_skip_dirs

        # Print each skipped directory once for visibility
        for d in "${skip_dirs[@]}"; do
            [[ -d "$d" ]] && echo "skip:  $d/"
        done

        if git rev-parse --git-dir > /dev/null 2>&1; then
            # Inside a git repo: enumerate tracked + untracked-non-ignored files.
            # git ls-files naturally skips .git, submodules, build artifacts, etc.
            file_list() {
                { git ls-files 2>/dev/null
                  git ls-files --others --exclude-standard 2>/dev/null
                } | sort -u
            }
        else
            # No git repo: fall back to find, applying filter rules per-file.
            file_list() {
                find . -type f | sed 's|^./||' | sort
            }
        fi

        while IFS= read -r f; do
            _base="$(basename "$f")"
            if [[ "$_base" == "Makefile" || "$_base" == Makefile.* ]]; then
                echo "skip:  $f"
            elif is_binary "$f"; then
                echo "skip:  $f (binary)"
            elif [[ -f "$f" ]]; then
                echo "clean: $f"
                trap '_sigint_defer' INT
                trim_file "$f"
                trap '_sigint_outer' INT
                if [[ $_interrupted -eq 1 ]]; then
                    echo ""
                    echo "cleanup: interrupted after completing $f."
                    exit 130
                fi
            fi
        done < <(file_list)
        ;;

    git)
        if ! git rev-parse --git-dir > /dev/null 2>&1; then
            echo "cleanup: not inside a git repository."
            echo "Use 'cleanup -all' to clean all files, or 'cleanup <file> ...' for specific files."
            exit 1
        fi

        # modified tracked files + untracked (not-ignored) files
        git_files=()
        while IFS= read -r f; do
            git_files+=("$f")
        done < <({ git diff --name-only HEAD 2>/dev/null
                    git ls-files --others --exclude-standard 2>/dev/null
                  } | sort -u)

        if [[ ${#git_files[@]} -eq 0 ]]; then
            echo "No modified or untracked files."
            exit 0
        fi

        for f in "${git_files[@]}"; do
            process_file "$f"
        done
        ;;

esac
