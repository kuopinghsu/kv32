# Environment Configuration for RISC-V SoC Project
# This file specifies toolchain paths for Verilator and RISC-V toolchain

# RISC-V Toolchain prefix
# Examples:
#   /home/user/opt/xpack-riscv-none-elf-gcc-15.2.0-1/bin/riscv-none-elf-
#   riscv64-unknown-elf-
#   riscv32-unknown-elf-
#RISCV_PREFIX=/opt/xpack/xpack-riscv-none-elf-gcc-15.2.0-1/bin/riscv-none-elf-
RISCV_PREFIX=/opt/riscv/bin/riscv64-unknown-elf-

# Verilator path
# Examples:
#   /home/user/opt/verilator/bin/verilator
#   verilator (if in PATH)
VERILATOR=/usr/local/bin/verilator

# Spike RISC-V ISA Simulator path
# Examples:
#   /home/user/opt/spike/bin/spike
#   spike (if in PATH)
SPIKE=/opt/riscv/bin/spike
SPIKE_INCLUDE=/opt/riscv/include

# Zephyr RTOS base directory
# Examples:
#   /home/user/zephyrproject/zephyr
#   /opt/zephyrproject/zephyr
ZEPHYR_BASE=/Users/kuoping/Zephyr/zephyrproject/zephyr

# Additional PATH directories (appended to PATH)
# Add paths to Yosys, SymbiYosys, and other EDA tools here if needed
# Also includes ~/.local/bin for kconfig-tweak (required by NuttX)
# Note: Edit the path below to use your actual home directory path
# Examples:
#   /home/user/opt/oss-cad-suite/bin
#   /opt/yosys/bin
PATH_APPEND=/opt/oss-cad-suite/bin:/Users/kuoping/.local/bin

# Explicit tool paths (override PATH-based defaults)
# Set these if tools are not found via PATH_APPEND above
YOSYS=/opt/oss-cad-suite/bin/yosys

# OpenRAM memory compiler
# Path to the OpenRAM installation directory (must contain openram.py).
# Used by 'make gen-mem' in syn/ to generate SRAM macros.
# Supports FreePDK45 (default). Run: make -C syn gen-mem
OPENRAM=/Users/kuoping/OpenRAM-1.2.48

# svlint SystemVerilog linter
# Path to the svlint binary.
# Set to the actual path if svlint is installed, or set to 'None' (without
# quotes) to skip svlint entirely.  If this variable is absent from this file
# (or env.config is not present), 'make lint-svlint' is also silently skipped.
# Examples:
#   /opt/svlint/bin/svlint
#   /usr/local/bin/svlint
#   None  (skip svlint)
SVLINT=/opt/svlint/bin/svlint
